{% extends 'base.html.twig' %}

{% block title %}
    {% if menu %}
        Commander :
        {{ menu.titre }}
    {% else %}
        Nouvelle commande
    {% endif %}
{% endblock %}

{% block body %}
    <section class="py-5">
        <div class="container px-4 px-lg-5">

            {% if menu and form %}
                {# ====== MODE FORMULAIRE : menu sélectionné ====== #}
                <div
                    class="row gx-4 gx-lg-5">

                    {# Colonne gauche : récap du menu #}
                    <div class="col-lg-5 mb-4">
                        <div class="card shadow-sm">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0">
                                    <i class="bi bi-journal-text"></i>
                                    Récapitulatif du menu
                                </h5>
                            </div>

                            {% if menu.plats|length > 0 and menu.plats|first.photo is not empty %}
                                {% set menuImage = path('app_admin_plat_image', {id: menu.plats|first.id}) %}
                            {% else %}
                                {% set menuImage = asset('images/menus/default.jpg') %}
                            {% endif %}
                            <img class="card-img-top" src="{{ menuImage }}" alt="{{ menu.titre }}" style="max-height: 200px; object-fit: cover;">

                            <div class="card-body">
                                <h4 class="fw-bolder">{{ menu.titre }}</h4>

                                {% if menu.description is not empty %}
                                    <p class="text-muted">{{ menu.description }}</p>
                                {% endif %}

                                {% if menu.regime is not null %}
                                    <span class="badge bg-secondary mb-2">
                                        <i class="bi bi-leaf"></i>
                                        {{ menu.regime.libelle }}</span>
                                {% endif %}
                                {% if menu.theme is not null %}
                                    <span class="badge bg-info text-dark mb-2">
                                        <i class="bi bi-palette"></i>
                                        {{ menu.theme.libelle }}</span>
                                {% endif %}

                                <hr>

                                <p class="mb-1">
                                    <strong>Prix par personne :</strong>
                                    {{ menu.prixParPersonne|number_format(2, ',', ' ') }}
                                    €</p>
                                <p class="mb-1">
                                    <strong>Minimum :</strong>
                                    {{ menu.nombrePersonneMinimum }}
                                    personne{{ menu.nombrePersonneMinimum > 1 ? 's' : '' }}</p>

                                {% if menu.plats|length > 0 %}
                                    <h6 class="mt-3 fw-bold">Plats inclus :</h6>
                                    <ul class="list-unstyled">
                                        {% for plat in menu.plats %}
                                            <li>
                                                <i class="bi bi-check-circle text-success"></i>
                                                {{ plat.titrePlat }}</li>
                                        {% endfor %}
                                    </ul>
                                {% endif %}

                                {# Info réduction #}
                                <div class="alert alert-info mt-3 mb-0">
                                    <i class="bi bi-percent"></i>
                                    <strong>Réduction :</strong>
                                    10% de réduction à partir de
                                    {{ seuil_reduction }}
                                    personnes !
                                </div>
                            </div>
                        </div>

                        {# Info livraison #}
                        <div class="card shadow-sm mt-3">
                            <div class="card-body">
                                <h6 class="fw-bold">
                                    <i class="bi bi-truck"></i>
                                    Informations livraison</h6>
                                <p class="mb-0 text-muted small">
                                    Livraison sur Bordeaux :
                                    <strong>5,00 €</strong><br>
                                    Hors Bordeaux :
                                    <strong>+ 0,59 € / km</strong><br>
                                    <em>Le prix final de livraison sera calculé et confirmé par notre équipe.</em>
                                </p>
                            </div>
                        </div>
                    </div>

                    {# Colonne droite : formulaire #}
                    <div class="col-lg-7">
                        <div class="card shadow-sm">
                            <div class="card-header bg-dark text-white">
                                <h5 class="mb-0">
                                    <i class="bi bi-cart-plus"></i>
                                    Votre commande
                                </h5>
                            </div>
                            <div
                                class="card-body p-4">
                                {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

                                <div class="mb-3">
                                    {{ form_label(form.datePrestation) }}
                                    {{ form_widget(form.datePrestation) }}
                                    {{ form_errors(form.datePrestation) }}
                                </div>

                                <div class="mb-3">
                                    {{ form_label(form.heureLivraison) }}
                                    {{ form_widget(form.heureLivraison) }}
                                    {{ form_errors(form.heureLivraison) }}
                                    <div class="form-text">Format : 12:00, 18:30, etc.</div>
                                </div>

                                <div class="mb-3">
                                    {{ form_label(form.nombrePersonne) }}
                                    {{ form_widget(form.nombrePersonne) }}
                                    {{ form_errors(form.nombrePersonne) }}
                                    <div class="form-text">
                                        Minimum :
                                        {{ menu.nombrePersonneMinimum }}
                                        personne{{ menu.nombrePersonneMinimum > 1 ? 's' : '' }}.
                                                                                À partir de
                                        {{ seuil_reduction }}
                                        personnes :
                                        <strong>-10% de réduction !</strong>
                                    </div>
                                </div>

                                <div class="mb-3 form-check">
                                    {{ form_widget(form.pretMateriel) }}
                                    {{ form_label(form.pretMateriel) }}
                                    {{ form_errors(form.pretMateriel) }}
                                </div>

                                <hr>

                                {% if recap_prix is defined and recap_prix %}
                                    {# === ÉTAPE 2 : Récap prix + confirmation === #}
                                    <div class="alert alert-success">
                                        <h5 class="fw-bold mb-3">
                                            <i class="bi bi-receipt"></i>
                                            Récapitulatif du prix
                                        </h5>
                                        <table class="table table-sm table-borderless mb-2">
                                            <thead class="visually-hidden">
                                                <tr>
                                                    <th>Description</th>
                                                    <th>Montant</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td>{{ form.vars.data.nombrePersonne }}
                                                        personne{{ form.vars.data.nombrePersonne > 1 ? 's' : '' }}
                                                        ×
                                                        {{ menu.prixParPersonne|number_format(2, ',', ' ') }}
                                                        €</td>
                                                    <td class="text-end">{{ prix_base|number_format(2, ',', ' ') }}
                                                        €</td>
                                                </tr>
                                                {% if reduction_appliquee %}
                                                    <tr class="text-success">
                                                        <td>
                                                            <i class="bi bi-percent"></i>
                                                            Réduction 10%</td>
                                                        <td class="text-end">-
                                                            {{ (prix_base - prix_final)|number_format(2, ',', ' ') }}
                                                            €</td>
                                                    </tr>
                                                {% endif %}
                                                <tr class="fw-bold fs-5 border-top">
                                                    <td>Total menu</td>
                                                    <td class="text-end">{{ prix_final|number_format(2, ',', ' ') }}
                                                        €</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <p class="text-muted small mb-0">
                                            <i class="bi bi-info-circle"></i>
                                            Le prix de livraison sera calculé et ajouté par notre équipe.
                                        </p>
                                    </div>
                                    <div class="form-check mb-3">
                                        <input class="form-check-input" type="checkbox" id="acceptCgv" onchange="document.getElementById('btnConfirmerCommande').disabled = !this.checked">
                                        <label class="form-check-label" for="acceptCgv">
                                            J'ai lu et j'accepte les
                                            <a href="#" data-bs-toggle="modal" data-bs-target="#conditionsVenteModal">conditions générales de vente</a>
                                        </label>
                                    </div>

                                    <div class="d-grid gap-2">
                                        <input type="hidden" name="_confirmed" value="1">
                                        <button type="submit" id="btnConfirmerCommande" class="btn btn-success btn-lg" disabled>
                                            <i class="bi bi-check-lg"></i>
                                            Confirmer la commande —
                                            {{ prix_final|number_format(2, ',', ' ') }}
                                            €
                                        </button>
                                        <a href="{{ path('app_commande_new', {menu: menu.id}) }}" class="btn btn-outline-secondary">
                                            <i class="bi bi-pencil"></i>
                                            Modifier ma commande
                                        </a>
                                    </div>
                                {% else %}
                                    {# === ÉTAPE 1 : Soumettre pour voir le prix === #}
                                    <div class="d-grid gap-2">
                                        <button type="submit" class="btn btn-success btn-lg">
                                            <i class="bi bi-calculator"></i>
                                            Voir le récapitulatif et le prix
                                        </button>
                                        <a href="{{ path('app_menu_index') }}" class="btn btn-outline-secondary">
                                            <i class="bi bi-arrow-left"></i>
                                            Retour aux menus
                                        </a>
                                    </div>
                                {% endif %}

                                {{ form_end(form) }}
                            </div>
                        </div>
                    </div>
                </div>

            {% else %}
                {# ====== MODE LISTING : pas de menu sélectionné ====== #}
                <div class="text-center mb-5">
                    <h2 class="fw-bolder">Nouvelle commande</h2>
                    <p class="lead text-muted">Choisissez un menu pour commencer votre commande</p>
                </div>

                <div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">
                    {% for menu in menus %}
                        <div class="col mb-5">
                            <div class="card h-100">

                                {% if menu.plats|length > 0 and menu.plats|first.photo is not empty %}
                                    {% set menuImage = path('app_admin_plat_image', {id: menu.plats|first.id}) %}
                                {% else %}
                                    {% set menuImage = asset('images/menus/default.jpg') %}
                                {% endif %}
                                <img class="card-img-top" src="{{ menuImage }}" alt="{{ menu.titre }}"/>

                                <div class="card-body p-4">
                                    <div class="text-center">
                                        {% if menu.regime is not null %}
                                            <span class="badge bg-secondary mb-2">{{ menu.regime.libelle }}</span>
                                        {% endif %}
                                        <h5 class="fw-bolder">{{ menu.titre }}</h5>
                                        {% if menu.description is not empty %}
                                            <p class="text-muted small">{{ menu.description }}</p>
                                        {% endif %}
                                    </div>
                                </div>

                                <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                                    <div class="text-center">
                                        {% if menu.getPrixParPersonne is not null %}
                                            <p class="fw-bold mb-2">{{ menu.getPrixParPersonne|number_format(2, ',', ' ') }}
                                                €</p>
                                        {% endif %}

                                        <a class="btn btn-outline-dark mt-auto" href="{{ path('app_menu_show', {id: menu.id}) }}">
                                            Voir le menu
                                        </a>

                                        {% if menu.getQuantiteRestante > 0 %}
                                            <a class="btn btn-success mt-2" href="{{ path('app_commande_new', {menu: menu.id}) }}">
                                                <i class="bi bi-cart-plus"></i>
                                                Commander
                                            </a>
                                        {% else %}
                                            <button class="btn btn-secondary mt-2" disabled>
                                                <i class="bi bi-x-circle"></i>
                                                Épuisé
                                            </button>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <p>Aucun menu disponible.</p>
                    {% endfor %}
                </div>
            {% endif %}

        </div>
    </section>
{% endblock %}
