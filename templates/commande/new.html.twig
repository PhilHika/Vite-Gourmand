{% extends 'base.html.twig' %}

{% block title %}
    {% if menu %}
        Commander : {{ menu.titre }}
    {% else %}
        Nouvelle commande
    {% endif %}
{% endblock %}

{% block body %}
    <section class="py-5">
        <div class="container px-4 px-lg-5">
            <div class="row gx-4 gx-lg-5 justify-content-center">

                {% if menu %}
                {# ====== Colonne gauche : récap du menu ====== #}
                <div class="col-lg-5 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">
                                <i class="bi bi-journal-text"></i> Récapitulatif du menu
                            </h5>
                        </div>

                        {% if menu.plats|length > 0 and menu.plats|first.photo is not empty %}
                            {% set menuImage = path('app_admin_plat_image', {id: menu.plats|first.id}) %}
                        {% else %}
                            {% set menuImage = asset('images/menus/default.jpg') %}
                        {% endif %}
                        <img class="card-img-top" src="{{ menuImage }}" alt="{{ menu.titre }}" style="max-height: 200px; object-fit: cover;">

                        <div class="card-body">
                            <h4 class="fw-bolder">{{ menu.titre }}</h4>
                            {% if menu.description is not empty %}
                                <p class="text-muted">{{ menu.description }}</p>
                            {% endif %}

                            {% if menu.regime is not null %}
                                <span class="badge bg-secondary mb-2"><i class="bi bi-leaf"></i> {{ menu.regime.libelle }}</span>
                            {% endif %}
                            {% if menu.theme is not null %}
                                <span class="badge bg-info text-dark mb-2"><i class="bi bi-palette"></i> {{ menu.theme.libelle }}</span>
                            {% endif %}
                            <hr>
                            <p class="mb-1"><strong>Prix par personne :</strong> {{ menu.prixParPersonne|number_format(2, ',', ' ') }} €</p>
                            <p class="mb-1"><strong>Minimum :</strong> {{ menu.nombrePersonneMinimum }} personne{{ menu.nombrePersonneMinimum > 1 ? 's' : '' }}</p>

                            {% if menu.plats|length > 0 %}
                                <h6 class="mt-3 fw-bold">Plats inclus :</h6>
                                <ul class="list-unstyled">
                                    {% for plat in menu.plats %}
                                        <li><i class="bi bi-check-circle text-success"></i> {{ plat.titrePlat }}</li>
                                    {% endfor %}
                                </ul>
                            {% endif %}

                            <div class="alert alert-info mt-3 mb-0">
                                <i class="bi bi-percent"></i>
                                <strong>Réduction :</strong> 10% de réduction à partir de {{ seuil_reduction }} personnes !
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm mt-3">
                        <div class="card-body">
                            <h6 class="fw-bold"><i class="bi bi-truck"></i> Informations livraison</h6>
                            <p class="mb-0 text-muted small">
                                Livraison sur Bordeaux : <strong>5,00 €</strong><br>
                                Hors Bordeaux : <strong>+ 0,59 € / km</strong><br>
                                <em>Le prix final de livraison sera calculé et confirmé par notre équipe.</em>
                            </p>
                        </div>
                    </div>
                </div>
                {% endif %}

                {# ====== Colonne : formulaire de commande ====== #}
                <div class="{% if menu %}col-lg-7{% else %}col-lg-8{% endif %}">
                    {% if not menu %}
                    <div class="text-center mb-4">
                        <h2 class="fw-bolder">Votre commande</h2>
                        <p class="lead text-muted">Étape 1 : Renseignez vos informations de livraison</p>
                    </div>
                    {% endif %}

                    <div class="card shadow-sm">
                        <div class="card-header bg-dark text-white">
                            <h5 class="mb-0">
                                <i class="bi bi-cart-plus"></i> {% if menu %}Finaliser la commande{% else %}Informations de livraison{% endif %}
                            </h5>
                        </div>
                        <div class="card-body p-4">
                            {{ form_start(form, {attr: {novalidate: 'novalidate', name: 'commande_form'}}) }}

                            <div class="mb-3">
                                {{ form_label(form.datePrestation) }}
                                {{ form_widget(form.datePrestation) }}
                                {{ form_errors(form.datePrestation) }}
                            </div>

                            <div class="mb-3">
                                {{ form_label(form.heureLivraison) }}
                                {{ form_widget(form.heureLivraison) }}
                                {{ form_errors(form.heureLivraison) }}
                                <div class="form-text">Format : 12:00, 18:30, etc.</div>
                            </div>

                            <div class="mb-3">
                                {{ form_label(form.nombrePersonne) }}
                                {{ form_widget(form.nombrePersonne) }}
                                {{ form_errors(form.nombrePersonne) }}
                                {% if menu %}
                                    <div class="form-text">
                                        Minimum : {{ menu.nombrePersonneMinimum }} personne{{ menu.nombrePersonneMinimum > 1 ? 's' : '' }}.
                                        À partir de {{ seuil_reduction }} personnes : <strong>-10% de réduction !</strong>
                                    </div>
                                {% endif %}
                            </div>

                            <div class="mb-3 form-check">
                                {{ form_widget(form.pretMateriel) }}
                                {{ form_label(form.pretMateriel) }}
                                {{ form_errors(form.pretMateriel) }}
                            </div>

                            <hr>

                            <h6 class="fw-bold text-primary">
                                <i class="bi bi-geo-alt"></i> Adresse de livraison
                            </h6>
                            <p class="text-muted small">Pré-remplie depuis votre profil. Vous pouvez la modifier si la livraison est à une adresse différente.</p>

                            <div class="mb-3">
                                {{ form_label(form.adresseLivraison) }}
                                {{ form_widget(form.adresseLivraison) }}
                                {{ form_errors(form.adresseLivraison) }}
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    {{ form_label(form.villeLivraison) }}
                                    {{ form_widget(form.villeLivraison) }}
                                    {{ form_errors(form.villeLivraison) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_label(form.paysLivraison) }}
                                    {{ form_widget(form.paysLivraison) }}
                                    {{ form_errors(form.paysLivraison) }}
                                </div>
                            </div>

                            <hr>

                            {% if recap_prix is defined and recap_prix %}
                                {# === ÉTAPE 2 : Récap prix + confirmation === #}
                                <div class="alert alert-success">
                                    <h5 class="fw-bold mb-3">
                                        <i class="bi bi-receipt"></i> Récapitulatif du prix
                                    </h5>
                                    <table class="table table-sm table-borderless mb-2">
                                        <thead class="visually-hidden">
                                            <tr><th>Description</th><th>Montant</th></tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td>{{ form.vars.data.nombrePersonne }} personne{{ form.vars.data.nombrePersonne > 1 ? 's' : '' }} × {{ menu.prixParPersonne|number_format(2, ',', ' ') }} €</td>
                                                <td class="text-end">{{ prix_base|number_format(2, ',', ' ') }} €</td>
                                            </tr>
                                            {% if reduction_appliquee %}
                                                <tr class="text-success">
                                                    <td><i class="bi bi-percent"></i> Réduction 10%</td>
                                                    <td class="text-end">- {{ (prix_base - prix_final)|number_format(2, ',', ' ') }} €</td>
                                                </tr>
                                            {% endif %}
                                            <tr class="fw-bold fs-5 border-top">
                                                <td class="pt-3">Total (hors livraison)</td>
                                                <td class="text-end pt-3">{{ prix_final|number_format(2, ',', ' ') }} €</td>
                                            </tr>
                                        </tbody>
                                    </table>

                                    <div class="alert alert-danger mt-3 mb-0" role="alert">
                                        <h6 class="alert-heading fw-bold mb-1">
                                            <i class="bi bi-exclamation-triangle-fill me-2"></i>Frais de livraison à calculer
                                        </h6>
                                        <p class="mb-0 small">
                                            Ce montant sera défini par notre équipe selon l'adresse saisie et viendra s'ajouter à votre total.<br>
                                            <strong>Exemple de tarif :</strong> Bordeaux à 5,00 € | Hors Bordeaux à +0,59 € / km.
                                        </p>
                                    </div>
                                </div>

                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" id="acceptCgv" onchange="document.getElementById('btnConfirmerCommande').disabled = !this.checked">
                                    <label class="form-check-label" for="acceptCgv">
                                        J'ai lu et j'accepte les
                                        <a href="#" data-bs-toggle="modal" data-bs-target="#conditionsVenteModal">conditions générales de vente</a>
                                    </label>
                                </div>

                                <div class="d-grid gap-2">
                                    <input type="hidden" name="_confirmed" value="1">
                                    <button type="submit" id="btnConfirmerCommande" class="btn btn-success btn-lg" disabled>
                                        <i class="bi bi-check-lg"></i> Confirmer la commande — {{ prix_final|number_format(2, ',', ' ') }} €
                                    </button>
                                    <a href="{{ path('app_commande_new', {menu: menu.id}) }}" class="btn btn-outline-secondary">
                                        <i class="bi bi-pencil"></i> Modifier ma commande
                                    </a>
                                </div>

                            {% else %}
                                {# === ÉTAPE 1 : Soumettre === #}
                                <div class="d-grid gap-2 mt-4">
                                    {% if menu %}
                                        <button type="submit" class="btn btn-success btn-lg">
                                            <i class="bi bi-calculator"></i> Étape suivante : Voir le récapitulatif
                                        </button>
                                    {% else %}
                                        <button type="button" class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#menuModal">
                                            <i class="bi bi-card-list"></i> Étape suivante : Choisir mon menu
                                        </button>
                                    {% endif %}
                                    <a href="{{ path('app_menu_index') }}" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left"></i> Retour au catalogue
                                    </a>
                                </div>
                            {% endif %}

                            {{ form_end(form) }}
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    {% if not menu %}
        <!-- Modal Sélection Menu -->
        <div class="modal fade" id="menuModal" tabindex="-1" aria-labelledby="menuModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title fw-bold" id="menuModalLabel"><i class="bi bi-card-list"></i> Choisissez votre menu</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body bg-light">
                        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                            {% for m in menus %}
                                <div class="col">
                                    <div class="card h-100 shadow-sm border-0">
                                        {% if m.plats|length > 0 and m.plats|first.photo is not empty %}
                                            {% set menuImage = path('app_admin_plat_image', {id: m.plats|first.id}) %}
                                        {% else %}
                                            {% set menuImage = asset('images/menus/default.jpg') %}
                                        {% endif %}
                                        <img class="card-img-top" src="{{ menuImage }}" alt="{{ m.titre }}" style="height: 15rem; object-fit: cover;"/>
                                        <div class="card-body">
                                            <div class="text-center mb-2">
                                                {% if m.regime is not null %}
                                                    <span class="badge bg-secondary mb-1">{{ m.regime.libelle }}</span>
                                                {% endif %}
                                            </div>
                                            <h5 class="fw-bolder text-center">{{ m.titre }}</h5>
                                            {% if m.description is not empty %}
                                                <p class="text-muted small text-center">{{ m.description|striptags }}</p>
                                            {% endif %}
                                        </div>
                                        <div class="card-footer bg-transparent border-top-0 d-grid gap-2">
                                            {% if m.getPrixParPersonne is not null %}
                                                <div class="text-center mb-2">
                                                    <p class="fw-bold mb-0">{{ m.getPrixParPersonne|number_format(2, ',', ' ') }} € <small class="text-muted fw-normal">/ pers.</small></p>
                                                    <span class="text-muted small"><i class="bi bi-people"></i> Min. {{ m.nombrePersonneMinimum }} pers.</span>
                                                </div>
                                            {% endif %}
                                            
                                            {% if m.getQuantiteRestante > 0 %}
                                                <button type="button" class="btn btn-success btn-choose-menu" data-menu-id="{{ m.id }}">
                                                    <i class="bi bi-check-circle"></i> Sélectionner ce menu
                                                </button>
                                            {% else %}
                                                <button class="btn btn-secondary" disabled><i class="bi bi-x-circle"></i> Épuisé</button>
                                            {% endif %}
                                            
                                            <a href="{{ path('app_menu_show', {id: m.id}) }}" target="_blank" class="btn btn-outline-dark">
                                                <i class="bi bi-box-arrow-up-right"></i> Voir les détails
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            {% else %}
                                <div class="col-12 text-center"><p class="text-muted">Aucun menu disponible pour le moment.</p></div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const buttons = document.querySelectorAll('.btn-choose-menu');
                const form = document.querySelector('form[name="commande_form"]');
                
                buttons.forEach(btn => {
                    btn.addEventListener('click', function() {
                        const menuId = this.dataset.menuId;
                        let action = form.getAttribute('action');
                        if (!action) {
                            action = window.location.pathname;
                        }
                        
                        // Assurer que les paramètres existants sont nettoyés ou gérés (en particulier 'menu')
                        if (action.includes('?menu=')) {
                            action = action.split('?')[0];
                        }
                        
                        form.setAttribute('action', action + '?menu=' + menuId);
                        
                        // Fermer la modale visuellement avant le rechargement de la page (optionnel)
                        const modal = bootstrap.Modal.getInstance(document.getElementById('menuModal'));
                        if (modal) modal.hide();

                        // Soumettre le formulaire
                        form.submit();
                    });
                });
            });
        </script>
    {% endif %}

{% endblock %}
