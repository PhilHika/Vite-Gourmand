{% extends 'base.html.twig' %}

{% block title %}Commande {{ commande.numeroCommande }}{% endblock %}

{% block body %}
    <section class="py-5">
        <div class="container px-4 px-lg-5">

            <div class="row justify-content-center">
                <div class="col-lg-8">

                    {# En-tête #}
                    <div class="text-center mb-4">
                        <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-check-lg fs-1"></i>
                        </div>
                        <h2 class="fw-bolder">Commande confirmée !</h2>
                        <p class="lead text-muted">
                            N° de commande :
                            <strong>{{ commande.numeroCommande }}</strong>
                        </p>
                    </div>

                    {# Détails de la commande #}
                    {% if editable and edit_form is not null %}
                    {{ form_start(edit_form) }}
                    {% endif %}
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-dark text-white">
                            <h5 class="mb-0">
                                <i class="bi bi-receipt"></i>
                                Détails de la commande
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <p>
                                        <strong>Date de commande :</strong><br>
                                        {{ commande.dateCommande|date('d/m/Y') }}
                                    </p>
                                    {% if editable and edit_form is not null %}
                                        <div class="mb-3">
                                            {{ form_label(edit_form.datePrestation) }}
                                            {{ form_widget(edit_form.datePrestation) }}
                                            {{ form_errors(edit_form.datePrestation) }}
                                        </div>
                                        <div class="mb-3">
                                            {{ form_label(edit_form.heureLivraison) }}
                                            {{ form_widget(edit_form.heureLivraison) }}
                                            {{ form_errors(edit_form.heureLivraison) }}
                                        </div>
                                    {% else %}
                                        <p>
                                            <strong>Date de prestation :</strong><br>
                                            {{ commande.datePrestation|date('d/m/Y') }}
                                        </p>
                                        <p>
                                            <strong>Heure de livraison :</strong><br>
                                            {{ commande.heureLivraison }}
                                        </p>
                                    {% endif %}
                                </div>
                                <div class="col-md-6">
                                    {% if editable and edit_form is not null %}
                                        <div class="mb-3">
                                            {{ form_label(edit_form.nombrePersonne) }}
                                            {{ form_widget(edit_form.nombrePersonne) }}
                                            {{ form_errors(edit_form.nombrePersonne) }}
                                        </div>
                                        <div class="mb-3 form-check">
                                            {{ form_widget(edit_form.pretMateriel) }}
                                            {{ form_label(edit_form.pretMateriel) }}
                                            {{ form_errors(edit_form.pretMateriel) }}
                                        </div>
                                    {% else %}
                                        <p>
                                            <strong>Nombre de personnes :</strong><br>
                                            {{ commande.nombrePersonne }}
                                        </p>
                                        <p>
                                            <strong>Prêt de matériel :</strong><br>
                                            {% if commande.pretMateriel %}
                                                <span class="badge bg-success">Oui</span>
                                            {% else %}
                                                <span class="badge bg-secondary">Non</span>
                                            {% endif %}
                                        </p>
                                    {% endif %}
                                    <p>
                                        <strong>Statut :</strong><br>
                                        <span class="badge bg-warning text-dark">{{ commande.statut|replace({_: ' '})|capitalize }}</span>
                                    </p>
                                    {% if editable and edit_form is not null %}
                                    <button type="submit" class="btn btn-success">
                                        <i class="bi bi-check-lg"></i>
                                        Sauvegarder
                                    </button>
                                {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Menu commandé #}
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">
                                <i class="bi bi-journal-text"></i>
                                Menu :
                                {{ commande.menu.titre }}
                            </h5>
                        </div>
                        <div class="card-body">
                            {% if commande.menu.description is not empty %}
                                <p class="text-muted">{{ commande.menu.description }}</p>
                            {% endif %}

                            {% if commande.menu.regime is not null %}
                                <span class="badge bg-secondary">
                                    <i class="bi bi-leaf"></i>
                                    {{ commande.menu.regime.libelle }}</span>
                            {% endif %}
                            {% if commande.menu.theme is not null %}
                                <span class="badge bg-info text-dark">
                                    <i class="bi bi-palette"></i>
                                    {{ commande.menu.theme.libelle }}</span>
                            {% endif %}

                            {% if commande.menu.plats|length > 0 %}
                                <h6 class="mt-3 fw-bold">Plats inclus :</h6>
                                <ul class="list-group list-group-flush">
                                    {% for plat in commande.menu.plats %}
                                        <li class="list-group-item">
                                            <i class="bi bi-check-circle text-success"></i>
                                            {{ plat.titrePlat }}
                                        </li>
                                    {% endfor %}
                                </ul>
                            {% endif %}
                        </div>
                    </div>

                    {# Tarification #}
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-dark text-white">
                            <h5 class="mb-0">
                                <i class="bi bi-calculator"></i>
                                Tarification
                            </h5>
                        </div>
                        <div class="card-body">
                            <table class="table table-borderless mb-0">
                                <thead class="visually-hidden">
                                    <tr>
                                        <th>Description</th>
                                        <th>Montant</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Prix par personne</td>
                                        <td class="text-end">{{ commande.menu.prixParPersonne|number_format(2, ',', ' ') }}
                                            €</td>
                                    </tr>
                                    <tr>
                                        <td>Nombre de personnes</td>
                                        <td class="text-end">× {{ commande.nombrePersonne }}</td>
                                    </tr>
                                    {% if reduction_appliquee %}
                                        <tr>
                                            <td>Sous-total</td>
                                            <td class="text-end text-decoration-line-through text-muted">{{ prix_sans_reduction|number_format(2, ',', ' ') }}
                                                €</td>
                                        </tr>
                                        <tr class="text-success">
                                            <td>
                                                <i class="bi bi-percent"></i>
                                                Réduction 10%</td>
                                            <td class="text-end">-
                                                {{ (prix_sans_reduction - commande.prixMenu)|number_format(2, ',', ' ') }}
                                                €</td>
                                        </tr>
                                    {% endif %}
                                    <tr class="border-top fw-bold fs-5">
                                        <td>Total menu</td>
                                        <td class="text-end text-primary">{{ commande.prixMenu|number_format(2, ',', ' ') }}
                                            €</td>
                                    </tr>
                                    <tr class="text-muted">
                                        <td>Livraison</td>
                                        <td class="text-end">
                                            <em>À confirmer par notre équipe</em>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    {# Informations livraison #}
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i>
                        <strong>Livraison :</strong>
                        5,00 € sur Bordeaux + 0,59 €/km hors Bordeaux. Le prix final sera confirmé par notre équipe et votre commande sera alors validée.
                    </div>

                    {# Boutons #}
                    <div class="d-flex gap-2 justify-content-center mt-4">
                        <a href="{{ path('app_menu_index') }}" class="btn btn-outline-dark">
                            <i class="bi bi-arrow-left"></i>
                            Retour aux menus
                        </a>
                        <a href="{{ path('app_profile') }}" class="btn btn-outline-dark">
                            <i class="bi bi-person"></i>
                            Mon profil
                        </a>
                        <a href="{{ path('app_home') }}" class="btn btn-primary">
                            <i class="bi bi-house"></i>
                            Accueil
                        </a>
                    </div>
                    {% if editable and edit_form is not null %}
                    {{ form_end(edit_form) }}
                    {% endif %}
                </div>
            </div>
        </div>
    </section>
{% endblock %}
