{% extends 'base.html.twig' %}

{% block title %}Modifier le rôle
{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="mb-4">Modifier le rôle</h1>

        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <h5 class="card-title mb-0">Utilisateur :
                    {{ utilisateur.prenom }}
                    {{ utilisateur.nom|upper }}</h5>
            </div>
            <div class="card-body">
                <p class="card-text text-muted mb-4">
                    <i class="bi bi-envelope"></i>
                    {{ utilisateur.email }}<br>
                    <i class="bi bi-shield-lock"></i>
                    Rôle actuel :
                    <strong>{{ utilisateur.role ? utilisateur.role.libelle : 'ROLE_USER' }}</strong>
                </p>

                {{ form_start(form) }}
                <div class="mb-3">
                    {{ form_label(form.role, 'Nouveau Rôle', {label_attr: {class: 'form-label fw-bold'}}) }}
                    {{ form_widget(form.role) }}
                    <div class="form-text">Sélectionnez le nouveau rôle à attribuer à cet utilisateur.</div>
                    {{ form_errors(form.role) }}
                </div>

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <a href="{{ path('app_admin_user_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i>
                        Annuler
                    </a>
                    <button class="btn btn-primary">
                        <i class="bi bi-save"></i>
                        Enregistrer les modifications
                    </button>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
