# solve npm install issue / CLI 5 known bug
#conflit interne aux dépendances ESLint installées par le scaffold Vue CLI 5 :
# @vue/eslint-config-standard@6.1.0  veut  eslint-plugin-vue@^7.0.0
# vue-app                            a     eslint-plugin-vue@8.7.1

# Solution : forcer l'installation des dépendances sans résoudre les conflits de version
legacy-peer-deps=true