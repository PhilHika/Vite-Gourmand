# Handle line endings automatically for files detected as text 
# and leave binary files untouched.
* text=auto

# Force LF for specific text files (crucial for Docker/Linux)
*.php text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.js text eol=lf
*.css text eol=lf
*.md text eol=lf
.env* text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
Dockerfile text eol=lf
compose*.yaml text eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

