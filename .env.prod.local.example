# .env.prod.local.example
# ⚠️  Ce fichier est un EXEMPLE - À ADAPTER et RENOMMER en .env.prod.local sur le serveur
# NE PAS COMMITER CE FICHIER (credentials sensibles)

###> symfony/framework-bundle ###
APP_SECRET=your-secret-key-here-change-this-in-production
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://vite_gourmand_user:your-secure-password@db-server.com:5432/vite_gourmand_prod?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
# Exemple avec OVH SMTP (adapter vos credentials)
MAILER_DSN="smtp://noreply%40vite-et-gourmand.fr:your-smtp-password@smtp.ovh.net:465?encryption=ssl"

# Alternative Gmail (avec App Password)
# MAILER_DSN="smtp://your-email%40gmail.com:your-app-password@smtp.gmail.com:587?encryption=tls"

# Alternative SendGrid
# MAILER_DSN="smtp://apikey:SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx@smtp.sendgrid.net:587?encryption=tls"
###< symfony/mailer ###

###> doctrine/mongodb-odm-bundle ###
MONGO_USER=mongo_prod_user
MONGO_PASSWORD=your-mongo-secure-password
MONGODB_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@mongo-server.com:27017
MONGODB_DBNAME=vite_gourmand
###< doctrine/mongodb-odm-bundle ###
